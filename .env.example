# Environment configuration for Docker deployment - DEFAULT ZIVE BRANDING
# This file is for deploying the standard ZIVE-branded version of the system
# For white-labeled client deployments, use .env.example.whitelabel instead
# Copy this file to .env and update with your actual values

# Domain Configuration
DOMAIN=resources.shopzive.com
NEXT_PUBLIC_API_URL=https://resources.shopzive.com
NEXT_PUBLIC_DOMAIN=resources.shopzive.com
FRONTEND_URL=https://resources.shopzive.com

# Backend Configuration
BACKEND_URL=http://backend:5001

# MongoDB Configuration
MONGODB_URI=mongodb://username:password@hostname:port/database
MONGODB_DB_NAME=media-management

# JWT Secret (use a strong random string in production)
JWT_SECRET=your-super-secret-jwt-key-here

# CORS Configuration - allowed origins for API access
ALLOWED_ORIGINS=https://resources.shopzive.com,http://localhost:3000

# Logging Configuration
LOG_LEVEL=warn

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
S3_BUCKET=your-s3-bucket-name

# Upload Configuration
HOST_UPLOAD_PATH=/path/to/host/uploads

# Email Configuration (Optional - for password reset emails)
# You can use either SendGrid OR Mailgun

# SendGrid Configuration
# Get your API key from https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=your-sendgrid-api-key-here
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# Mailgun Configuration (Alternative to SendGrid)
# Get your API key from https://app.mailgun.com/app/account/security/api_keys
# MAILGUN_API_KEY=your-mailgun-api-key-here
# MAILGUN_DOMAIN=yourdomain.com
# MAILGUN_FROM_EMAIL=noreply@yourdomain.com

# Optional: Force a specific mail driver (sendgrid or mailgun)
# If not set, auto-detects based on available configuration
# MAIL_DRIVER=sendgrid