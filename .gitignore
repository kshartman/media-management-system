# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
**/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env
.env.local
.env.*.local
.env.next3k
.env.*.next3k
.env.local.zive
.env.docker.zive
server/.env.zive

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.env
.*.env
**/.claude/settings.local.json
*.code-workspace

#--- temp files
\#*
*\#
*~
.\#*
.*\#

# VS Code settings
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
!.vscode/tasks.json
# Exclude chrome debug profile
.vscode/chrome-debug-profile/

# Server uploads (temp files and user uploads)
server/uploads/*.zip
server/uploads/[0-9]*
server/backend.log

# White-label client configurations
src/config/brand.config.*.ts
!src/config/brand.config.ts
!src/config/brand.config.example-client.ts

# Brand overlay folders (private repos for client-specific configurations)
*-brand/
!acme-brand/  # Keep the example brand folder for reference

# Public directory - ignore everything except specific files
public/*
# Keep the default Next.js assets that were already tracked
!public/file.svg
!public/globe.svg
!public/next.svg
!public/vercel.svg
!public/window.svg

