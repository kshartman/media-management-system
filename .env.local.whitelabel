# Local Development Environment Variables - WHITELABEL BRANDING
# This file is for local development with the whitelabel-branded system
# This contains actual local development values for whitelabel configuration

# Domain Configuration (Local Development)
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_DOMAIN=localhost:3000

# CORS Configuration for Development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002,http://localhost:5000,http://127.0.0.1:3000

# Brand Configuration
NEXT_PUBLIC_BRAND_CONFIG=whitelabel