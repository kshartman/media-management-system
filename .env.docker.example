# Production/Docker Deployment Configuration
# Copy this to .env for Docker deployment
# For local development, use .env.local and server/.env instead

# Domain Configuration
NEXT_PUBLIC_DOMAIN=example.com
NEXT_PUBLIC_API_URL=https://example.com/api

# Backend URL for internal communication (Docker service name)
BACKEND_URL=http://backend:5001

# MongoDB Configuration (External)
MONGODB_URI=mongodb://username:password@host:port/database
MONGODB_DB_NAME=mongo-database-name

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-here

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=your-s3-bucket-name
S3_BUCKET=your-s3-bucket-name
USE_S3_STORAGE=true

# Upload Path (Host filesystem path that will be mounted)
HOST_UPLOAD_PATH=/path/to/host/uploads