# ACME Brand — Local Development Environment (EXAMPLE)
#
# For running the frontend (Next.js) + backend (Express) directly on your machine
# without Docker.  Copy to .env.local and customize.
#
#   Frontend:  npm run dev          → http://localhost:3000
#   Backend:   cd server && npm run dev  → http://localhost:3001

# ── Brand ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_BRAND_CONFIG=acme                          # REQUIRED — matches config filename

# ── Domain (local dev) ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_DOMAIN=localhost:3000

# ── CORS ────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5000,http://127.0.0.1:3000

# ── Database ────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/media-management-dev  # REQUIRED
MONGODB_DB_NAME=media-management-dev                        # REQUIRED

# ── Authentication ──────────────────────────────────────────────────────
JWT_SECRET=local-development-secret-key-change-for-production  # REQUIRED (min 32 chars)

# ── Logging ─────────────────────────────────────────────────────────────
LOG_LEVEL=debug

# ── Storage ─────────────────────────────────────────────────────────────
# Local disk is the default for development — files go to server/uploads/
# USE_S3_STORAGE=false                                 # default when omitted

# Uncomment to use S3 in local dev (e.g., to test upload/download paths):
# USE_S3_STORAGE=true
# AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
# AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
# AWS_REGION=us-east-1
# S3_BUCKET=acme-media-bucket-dev
# S3_CUSTOM_DOMAIN=cdn-dev.acmecorp.example.com       # optional — CDN domain

# ── Email (optional for local dev) ─────────────────────────────────────
# Most local dev doesn't need email.  Uncomment to test password-reset flow.
# MAIL_DRIVER=sendgrid                                 # optional — sendgrid | mailgun
# SENDGRID_API_KEY=your-sendgrid-test-api-key
# SENDGRID_FROM_EMAIL=dev@acmecorp.example.com
# FRONTEND_URL=http://localhost:3000

# Mailgun (alternative to SendGrid)
# MAILGUN_API_KEY=your-mailgun-api-key
# MAILGUN_DOMAIN=acmecorp.example.com
# MAILGUN_FROM_EMAIL=dev@acmecorp.example.com
