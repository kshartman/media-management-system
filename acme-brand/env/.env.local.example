# ACME Brand - Local Development Environment Configuration (EXAMPLE)
# Copy this file to .env.local and customize for your local development

# Domain Configuration (Local Development)
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_DOMAIN=localhost:3000

# CORS Configuration for Development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5000,http://127.0.0.1:3000

# Brand Configuration
NEXT_PUBLIC_BRAND_CONFIG=acme

# MongoDB Configuration (use your local/dev MongoDB)
MONGODB_URI=mongodb://localhost:27017/media-management-dev
MONGODB_DB_NAME=media-management-dev

# JWT Secret (can use a simpler one for local dev)
JWT_SECRET=local-development-secret-key-change-for-production

# AWS S3 Configuration (optional for local dev)
# USE_S3_STORAGE=false  # Use local storage for development
# Or use S3 for local dev:
# AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
# AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
# AWS_REGION=us-east-1
# S3_BUCKET=acme-media-bucket-dev
# USE_S3_STORAGE=true

# Email Configuration (optional for local dev)
# SENDGRID_API_KEY=your-sendgrid-test-api-key
# SENDGRID_FROM_EMAIL=dev@acmecorp.example.com
# FRONTEND_URL=http://localhost:3000

# Logging
LOG_LEVEL=debug
