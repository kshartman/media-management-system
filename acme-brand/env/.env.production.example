# ACME Brand - Production Environment Configuration (EXAMPLE)
# Copy this file and replace all placeholder values with real credentials
# For security, encrypt this file with GPG: gpg -c .env.production -o env.production.gpg

# Brand Configuration
NEXT_PUBLIC_BRAND_CONFIG=acme

# Domain Configuration
DOMAIN=media.acmecorp.example.com
NEXT_PUBLIC_API_URL=https://${DOMAIN}/api
NEXT_PUBLIC_DOMAIN=${DOMAIN}
FRONTEND_URL=https://${DOMAIN}

# Backend Configuration
BACKEND_URL=http://backend:5001

# MongoDB Configuration
MONGODB_URI=mongodb://username:password@your-mongodb-host:27017/?ssl=true&retryWrites=false&loadBalanced=false&connectTimeoutMS=10000&authSource=media-management&authMechanism=SCRAM-SHA-256
MONGODB_DB_NAME=media-management

# JWT Secret (IMPORTANT: Generate a strong random string)
# Generate with: openssl rand -base64 48
JWT_SECRET=REPLACE-WITH-STRONG-RANDOM-STRING-MIN-32-CHARS

# CORS Configuration
ALLOWED_ORIGINS=https://${DOMAIN},http://${DOMAIN}

# Logging Configuration
LOG_LEVEL=info

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
AWS_REGION=us-east-1
S3_BUCKET=acme-media-bucket
USE_S3_STORAGE=true
# S3_CUSTOM_DOMAIN=cdn.acmecorp.example.com  # Optional: CloudFront or custom domain

# Upload Configuration
HOST_UPLOAD_PATH=/usr/local/acme/uploads

# Email Configuration (Choose SendGrid OR Mailgun)

# SendGrid Configuration
SENDGRID_API_KEY=SG.your-sendgrid-api-key-here
SENDGRID_FROM_EMAIL=noreply@acmecorp.example.com

# Mailgun Configuration (Alternative to SendGrid)
# MAILGUN_API_KEY=your-mailgun-api-key-here
# MAILGUN_DOMAIN=acmecorp.example.com
# MAILGUN_FROM_EMAIL=noreply@acmecorp.example.com

# Optional: Force a specific mail driver (sendgrid or mailgun)
# MAIL_DRIVER=sendgrid
