# ACME Brand — Backend-Only Server Environment (EXAMPLE)
#
# For non-Docker deployments where the Express backend runs directly on the host
# (e.g., bare Node.js behind nginx, or a systemd service).
#
# Copy to server/.env and replace placeholders.
# The frontend reads .env / .env.local; this file is for the backend only.

# ── Server ──────────────────────────────────────────────────────────────
PORT=5001                                              # Express listen port
NODE_ENV=production

# ── Domain ──────────────────────────────────────────────────────────────
DOMAIN=media.acmecorp.example.com                      # REQUIRED
FRONTEND_URL=https://${DOMAIN}

# ── Database ────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://username:password@mongodb-host:27017/?ssl=true&retryWrites=false&loadBalanced=false&connectTimeoutMS=10000&authSource=media-management&authMechanism=SCRAM-SHA-256  # REQUIRED
MONGODB_DB_NAME=media-management                       # REQUIRED

# ── Authentication ──────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=REPLACE-WITH-STRONG-RANDOM-STRING           # REQUIRED (min 32 chars)

# ── CORS ────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://${DOMAIN},http://localhost:3000

# ── Logging ─────────────────────────────────────────────────────────────
LOG_LEVEL=info                                         # debug | info | warn | error

# ── Storage ─────────────────────────────────────────────────────────────
# Option A: AWS S3 (recommended for production)
USE_S3_STORAGE=true                                    # REQUIRED — true or false
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID               # required if USE_S3_STORAGE=true
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY        # required if USE_S3_STORAGE=true
AWS_REGION=us-east-1                                   # required if USE_S3_STORAGE=true
S3_BUCKET=acme-media-bucket                            # required if USE_S3_STORAGE=true
# S3_CUSTOM_DOMAIN=cdn.acmecorp.example.com            # optional — CloudFront / CDN domain

# Option B: Local disk storage
# USE_S3_STORAGE=false
# UPLOAD_PATH=/usr/local/acme/uploads                  # absolute path on the host

# ── Email (optional — for password-reset emails) ───────────────────────
# MAIL_DRIVER=sendgrid                                 # optional — sendgrid | mailgun

# SendGrid
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@acmecorp.example.com

# Mailgun (alternative)
# MAILGUN_API_KEY=your-mailgun-api-key
# MAILGUN_DOMAIN=acmecorp.example.com
# MAILGUN_FROM_EMAIL=noreply@acmecorp.example.com
