# ACME Brand - Docker Production Environment Configuration (EXAMPLE)
# This file is used for Docker Compose deployments
# Copy and customize, then encrypt with GPG for security

# Brand Configuration
NEXT_PUBLIC_BRAND_CONFIG=acme

# Domain Configuration
DOMAIN=media.acmecorp.example.com
NEXT_PUBLIC_API_URL=https://${DOMAIN}/api
NEXT_PUBLIC_DOMAIN=${DOMAIN}
FRONTEND_URL=https://${DOMAIN}

# Backend Configuration
BACKEND_URL=http://backend:5001

# MongoDB Configuration
MONGODB_URI=mongodb://username:password@mongodb-host:27017/?ssl=true&retryWrites=false&loadBalanced=false&connectTimeoutMS=10000&authSource=media-management&authMechanism=SCRAM-SHA-256
MONGODB_DB_NAME=media-management

# JWT Secret (Generate with: openssl rand -base64 48)
JWT_SECRET=REPLACE-WITH-STRONG-RANDOM-STRING

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002,https://${DOMAIN},http://${DOMAIN}

# Logging
LOG_LEVEL=info

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
AWS_REGION=us-east-1
S3_BUCKET=acme-media-bucket
USE_S3_STORAGE=true

# Upload Configuration
HOST_UPLOAD_PATH=/usr/local/acme/uploads

# Email Configuration
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@acmecorp.example.com
