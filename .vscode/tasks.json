{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Client & Server",
      "dependsOn": [
        "Start Client",
        "Start Server"
      ],
      "problemMatcher": []
    },
    {
      "label": "Start Client",
      "type": "npm",
      "script": "dev",
      "path": "",
      "problemMatcher": [
        {
          "pattern": [
            {
              "regexp": ".",
              "file": 1,
              "location": 2,
              "message": 3
            }
          ],
          "background": {
            "activeOnStart": true,
            "beginsPattern": "^.*",
            "endsPattern": "Ready in|ready - started server|ready - compiled|successfully compiled"
          }
        }
      ],
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Start Server",
      "type": "npm",
      "script": "dev",
      "path": "server/",
      "problemMatcher": [
        {
          "pattern": [
            {
              "regexp": ".",
              "file": 1,
              "location": 2,
              "message": 3
            }
          ],
          "background": {
            "activeOnStart": true,
            "beginsPattern": "^.*",
            "endsPattern": "Server is running on port|Connected to MongoDB successfully"
          }
        }
      ],
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    }
  ]
}