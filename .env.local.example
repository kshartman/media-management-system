# Local Development Environment Variables
# This file is for local development with the optional whitelabel branding
# Set the NEXT_PUBLIC_BRAND_CONFIG if not using default (ZIVE)
# Copy to .env.local

# Domain Configuration (Local Development)
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_DOMAIN=localhost:3000

# Brand Configuration (unset for default)
# NEXT_PUBLIC_BRAND_CONFIG=your-brand-name
