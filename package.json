{
  "name": "media-management-system",
  "version": "0.2.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0",
    "next3k": "cp .env.local.next3k .env.local && next dev --hostname 0.0.0.0",
    "build": "next build",
    "start": "next start",
    "lint": "eslint \"src/**/*.{js,jsx,ts,tsx}\" --format=stylish",
    "lint:full": "eslint \"src/**/*.{js,jsx,ts,tsx}\" --format=unix",
    "lint:fix": "eslint \"src/**/*.{js,jsx,ts,tsx}\" --fix",
    "lint:strict": "eslint \"src/**/*.{js,jsx,ts,tsx}\" --max-warnings=0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tiptap/extension-bold": "^2.26.4",
    "@tiptap/extension-bullet-list": "^2.26.4",
    "@tiptap/extension-color": "^2.26.4",
    "@tiptap/extension-heading": "^2.26.4",
    "@tiptap/extension-italic": "^2.26.4",
    "@tiptap/extension-list-item": "^2.26.4",
    "@tiptap/extension-ordered-list": "^2.26.4",
    "@tiptap/extension-paragraph": "^2.26.4",
    "@tiptap/extension-strike": "^2.26.4",
    "@tiptap/extension-text-style": "^2.26.4",
    "@tiptap/extension-underline": "^2.26.4",
    "@tiptap/pm": "^2.26.4",
    "@tiptap/react": "^2.26.4",
    "@tiptap/starter-kit": "^2.26.4",
    "date-fns": "^4.1.0",
    "lodash": "^4.17.21",
    "next": "^15.5.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@tailwindcss/line-clamp": "^0.4.4",
    "@types/lodash": "^4.17.20",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.32.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.38.0",
    "eslint-config-next": "^15.5.6",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "typescript": "^5"
  }
