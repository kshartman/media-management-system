# White-label Environment Configuration Template
# Copy this file to .env for deployment with a specific client brand

# Brand Configuration
# Set this to the name of your brand config file (without extension)
# e.g., 'example-client' will load brand.config.example-client.js
NEXT_PUBLIC_BRAND_CONFIG=default

# Domain Configuration
# Replace CLIENT_DOMAIN with your actual domain
CLIENT_DOMAIN=resources.yourclient.com
DOMAIN=${CLIENT_DOMAIN}
NEXT_PUBLIC_API_URL=https://${CLIENT_DOMAIN}
NEXT_PUBLIC_DOMAIN=${CLIENT_DOMAIN}
FRONTEND_URL=https://${CLIENT_DOMAIN}

# Backend Configuration
BACKEND_URL=http://backend:5001

# MongoDB Configuration
MONGODB_URI=mongodb://username:password@hostname:port/database
MONGODB_DB_NAME=media-management

# JWT Secret (use a strong random string in production)
JWT_SECRET=your-super-secret-jwt-key-here

# CORS Configuration - update with your client domain
ALLOWED_ORIGINS=https://${CLIENT_DOMAIN},http://localhost:3000

# Logging Configuration
LOG_LEVEL=warn

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
S3_BUCKET=your-s3-bucket-name

# Upload Configuration
HOST_UPLOAD_PATH=/path/to/host/uploads

# Email Configuration (Optional - for password reset emails)
# You can use either SendGrid OR Mailgun

# SendGrid Configuration
SENDGRID_API_KEY=your-sendgrid-api-key-here
SENDGRID_FROM_EMAIL=noreply@${CLIENT_DOMAIN}

# Mailgun Configuration (Alternative to SendGrid)
# MAILGUN_API_KEY=your-mailgun-api-key-here
# MAILGUN_DOMAIN=${CLIENT_DOMAIN}
# MAILGUN_FROM_EMAIL=noreply@${CLIENT_DOMAIN}

# Optional: Force a specific mail driver (sendgrid or mailgun)
# MAIL_DRIVER=sendgrid